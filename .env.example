# SQL Server connection
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
SQLSERVER_SERVER=.\SQLEXPRESS
SQLSERVER_DATABASE=HOCHIEU
SQLSERVER_TRUSTED_CONNECTION=true
SQLSERVER_TRUST_SERVER_CERTIFICATE=true
SQLSERVER_USERNAME=
SQLSERVER_PASSWORD=

# OCR settings
OCR_IMAGE_INPUT_DIR=D:/DocHochieu/Backend/images
RENAME_IMAGE_INPUT_DIR=D:/DocHochieu/Backend/images
IMPORT_SOURCE_IMAGE_INPUT_DIR=D:/DocHochieu/Backend/imagesGoc
IMPORT_TARGET_IMAGE_OUTPUT_DIR=D:/DocHochieu/Backend/images
OCR_LANGUAGE=en
PADDLE_OCR_VERSION=PP-OCRv5
PADDLE_OCR_DEVICE=cpu
PADDLE_PDX_MODEL_SOURCE=BOS
PADDLE_USE_DOC_ORIENTATION_CLASSIFY=true
PADDLE_USE_TEXTLINE_ORIENTATION=true
OCR_AUTO_ROTATE_AND_OVERWRITE=true
PADDLE_DOC_ORIENTATION_MODEL_DIR=C:/Users/Admin/.paddlex/official_models/PP-LCNet_x1_0_doc_ori
PADDLE_TEXTLINE_ORIENTATION_MODEL_DIR=C:/Users/Admin/.paddlex/official_models/PP-LCNet_x1_0_textline_ori
PADDLE_TEXT_DETECTION_MODEL_DIR=D:/DocHochieu/Backend/models/paddle/PP-OCRv5_server_det
PADDLE_TEXT_RECOGNITION_MODEL_DIR=D:/DocHochieu/Backend/models/paddle/en_PP-OCRv5_mobile_rec

# API settings
API_HOST=127.0.0.1
API_PORT=8000
APP_LOG_DIR=D:/DocHochieu/Backend/logs
FRONTEND_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
